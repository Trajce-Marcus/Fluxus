{
  "name": "fluxus",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:sdm": "npm run dev --workspace=@fluxus/sdm",
    "dev:page-builder": "npm run dev --workspace=@fluxus/page-builder",
    "build:sdm": "npm run build --workspace=@fluxus/sdm",
    "build:page-builder": "npm run build --workspace=@fluxus/page-builder",
    "build": "npm run build --workspaces --if-present"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  }
}
