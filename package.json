{
  "name": "fluxus",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:all",
    "dev:all": "concurrently -n server,sdm,pages -c blue,green,magenta \"npm:dev:server\" \"npm:dev:sdm\" \"npm:dev:page-builder\"",
    "dev:sdm": "npm run dev --workspace=@fluxus/sdm",
    "dev:page-builder": "npm run dev --workspace=@fluxus/page-builder",
    "dev:server": "npm run dev --workspace=@fluxus/server",
    "seed:server": "npm run seed --workspace=@fluxus/server",
    "build:sdm": "npm run build --workspace=@fluxus/sdm",
    "build:page-builder": "npm run build --workspace=@fluxus/page-builder",
    "build": "npm run build --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "drizzle-orm": "^0.44.2",
    "typescript": "^5.3.3"
  }
}
