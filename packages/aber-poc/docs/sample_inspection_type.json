{
  "_comment": "POC1 sample config — hand-edited. Three record types: Asset Types, Assets, Inspection Jobs. All IDs use plural entity naming. Valid against SDM_Schema_Reference.md. Hooks are present in shape but bodies are not executed this cut (stubbed). show_condition and non-text attribute types are omitted (deferred).",

  "recordTypes": [
    {
      "id": "rt_asset_types",
      "name": "Asset Types",
      "description": "A classification of asset (e.g. Pump, Valve, Pipe).",
      "workflow_ref": "wf_asset_types",
      "id_field": "code",
      "custom_fields": [
        { "key": "code",        "type": "text", "default": "", "required": true, "unique": true, "immutable": true, "indexed": true },
        { "key": "description", "type": "text", "default": "" },
        { "key": "expired",     "type": "text", "default": "false" }
      ]
    },
    {
      "id": "rt_assets",
      "name": "Assets",
      "description": "A physical asset belonging to a type.",
      "workflow_ref": "wf_assets",
      "custom_fields": [
        { "key": "asset_no",      "type": "text", "default": "", "required": true, "unique": true, "indexed": true },
        { "key": "status",        "type": "text", "default": "Active", "indexed": true },
        { "key": "description",   "type": "text", "default": "" },
        { "key": "asset_type_id", "type": "text", "default": "", "required": true, "indexed": true, "fk_record_type": "rt_asset_types", "fk_display_field": "code" }
      ]
    },
    {
      "id": "rt_jobs",
      "name": "Jobs",
      "description": "A generic job",
      "workflow_ref": "wf_jobs",
      "custom_fields": [
        { "key": "job_type",   "type": "text", "default": "", "required": true },
        { "key": "status",     "type": "text", "default": "Raised", "indexed": true },
        { "key": "location",   "type": "text", "default": "", "required": true },
        { "key": "due_date",   "type": "text", "default": "", "required": true },
        { "key": "work_group", "type": "text", "default": "" }
      ]
    }
  ],

  "workflows": [
    {
      "id": "wf_asset_types",
      "name": "Asset Types",
      "description": "Manage asset type records.",
      "activities": [
        {
          "id": "act_create_asset_types",
          "name": "Create Asset Type",
          "description": "Creates a new Asset Type record.",
          "sort_order": 0,
          "record_map": "CREATE",
          "attributes": [
            { "key": "code",        "label": "Code",        "description": "Short unique code for this type.", "type": "text" },
            { "key": "description", "label": "Description", "description": "Human-readable description.",      "type": "text" }
          ],
          "before_hook": null,
          "after_hook": null
        },
        {
          "id": "act_update_asset_types",
          "name": "Update Asset Type",
          "description": "Update the description of an Asset Type.",
          "sort_order": 1,
          "record_map": "UPDATE",
          "attributes": [
            { "key": "description", "label": "Description", "description": "Updated description.", "type": "text" }
          ],
          "before_hook": null,
          "after_hook": null
        },
        {
          "id": "act_delete_asset_types",
          "name": "Delete Asset Type",
          "description": "Delete this Asset Type record.",
          "sort_order": 2,
          "record_map": "DELETE",
          "_comment": "record_map:DELETE — implemented. 'confirm' attribute must equal 'DELETE' exactly; any other value is a no-op. before_hook validation deferred.",
          "attributes": [
            { "key": "confirm", "label": "Confirm", "description": "Type DELETE to confirm removal.", "type": "text" }
          ],
          "before_hook": null,
          "after_hook": null
        }
      ]
    },
    {
      "id": "wf_assets",
      "name": "Assets",
      "description": "Manage asset records.",
      "activities": [
        {
          "id": "act_create_assets",
          "name": "Create Asset",
          "description": "Creates a new Asset record.",
          "sort_order": 0,
          "record_map": "CREATE",
          "attributes": [
            { "key": "asset_no",      "label": "Asset No",    "description": "Unique asset number.",                "type": "text" },
            { "key": "description",   "label": "Description", "description": "Description of the asset.",           "type": "text" },
            { "key": "asset_type_id", "label": "Asset Type",  "description": "Select the parent Asset Type record.", "type": "text", "fk_record_type": "rt_asset_types", "fk_display_field": "code" }
          ],
          "before_hook": null,
          "after_hook": null
        },
        {
          "id": "act_update_assets",
          "name": "Update Asset",
          "description": "Update asset details.",
          "sort_order": 1,
          "record_map": "UPDATE",
          "attributes": [
            { "key": "description",   "label": "Description", "description": "Updated description.", "type": "text" },
            { "key": "status",        "label": "Status",      "description": "Current status.",       "type": "text" },
            { "key": "asset_type_id", "label": "Asset Type",  "description": "Reclassify the asset.", "type": "text", "fk_record_type": "rt_asset_types", "fk_display_field": "code" }
          ],
          "before_hook": null,
          "after_hook": null
        },
        {
          "id": "act_delete_assets",
          "name": "Delete Asset",
          "description": "Delete this Asset record.",
          "sort_order": 2,
          "record_map": "DELETE",
          "_comment": "record_map:DELETE — implemented. 'confirm' attribute must equal 'DELETE' exactly.",
          "attributes": [
            { "key": "confirm", "label": "Confirm", "description": "Type DELETE to confirm removal.", "type": "text" }
          ],
          "before_hook": null,
          "after_hook": null
        }
      ]
    },
    {
      "id": "wf_jobs",
      "name": "Job Workflows",
      "description": "Planned inspection of a road asset",
      "activities": [
        {
          "id": "act_raise_inspection_jobs",
          "name": "Raise Inspection",
          "description": "Creates a new Inspection Job and captures its opening data.",
          "sort_order": 0,
          "record_map": "CREATE",
          "_comment": "record_map:CREATE — surfaced at the GRID level (no anchor). On submit, attributes whose key matches a custom_field key are written to the new Record. ACCEPTABLE BEHAVIOUR, DO NOT FIX: 'notes' has no matching custom field, so it is captured then silently dropped on create — intended (SDM update 1.9.3 rule 2), not a bug; do not add a notes field or error. ACCEPTABLE BEHAVIOUR, DO NOT FIX: 'status' is not captured here and no hook runs this cut, so it stays 'Raised' permanently — intended; do not add a non-activity write path to change it. See POC1_Runtime_UI_Scope.md §7a.",
          "attributes": [
            { "key": "location",   "label": "Location",    "description": "Where the inspection is.",            "type": "text" },
            { "key": "due_date",   "label": "Due Date",    "description": "When it is due (text for now).",       "type": "text" },
            { "key": "work_group", "label": "Work Group",  "description": "Responsible group.",                   "type": "text" },
            { "key": "notes",      "label": "Raise Notes", "description": "Free notes at raise time — not stored on the Record (no matching custom field).", "type": "text" }
          ],
          "before_hook": null,
          "after_hook": null
        },
        {
          "id": "act_record_finding_inspection_jobs",
          "name": "Record Finding",
          "description": "Capture inspection findings against the Job.",
          "sort_order": 1,
          "attributes": [
            { "key": "condition_rating", "label": "Condition Rating", "description": "Observed condition.", "type": "text" },
            { "key": "notes",            "label": "Notes",            "description": "Inspector notes.",    "type": "text" },
            { "key": "hazard_found",     "label": "Hazard Found?",    "description": "yes / no.",           "type": "text" }
          ],
          "before_hook": null,
          "after_hook": {
            "_comment": "Shape only — NOT executed this cut. When hooks are staged in, this would conditionally spawn a Hazard Record. Bodies/semantics deferred (SDM 1.6/1.7).",
            "timing": "after",
            "commands": [
              {
                "condition": "<expr deferred> hazard_found = \"yes\"",
                "action": "<deferred> create Record \"Hazard\", linked to this Job"
              }
            ]
          }
        },
        {
          "id": "act_close_inspection_jobs",
          "name": "Close Inspection",
          "description": "Mark the inspection complete.",
          "sort_order": 2,
          "attributes": [
            { "key": "completed_by", "label": "Completed By", "description": "Who closed it.", "type": "text" }
          ],
          "before_hook": null,
          "after_hook": {
            "_comment": "Shape only — NOT executed this cut. Would set anchor Record status = Complete once hooks are staged in.",
            "timing": "after",
            "commands": [
              { "action": "<deferred> set anchor Record status = \"Complete\"" }
            ]
          }
        }
      ]
    }
  ]
}
