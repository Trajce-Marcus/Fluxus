{
  "recordType": {
    "id": "rt_work_orders",
    "name": "Work Orders",
    "description": "A work order raised against a job.",
    "workflow_ref": "wf_work_orders",
    "id_field": "id",
    "custom_fields": [
      {
        "key": "id",
        "type": "text",
        "default": "",
        "required": true,
        "unique": true,
        "immutable": true,
        "indexed": true
      },
      {
        "key": "job_id",
        "type": "fk_ref",
        "default": "",
        "required": true,
        "indexed": true,
        "fk_record_type": "rt_jobs",
        "fk_display_field": "job_no"
      },
      {
        "key": "activity_code",
        "type": "text",
        "default": "",
        "required": true
      },
      {
        "key": "problem_code",
        "type": "text",
        "default": ""
      },
      {
        "key": "status",
        "type": "text",
        "default": "Raised",
        "indexed": true
      },
      {
        "key": "due_date",
        "type": "text",
        "default": ""
      },
      {
        "key": "start_date",
        "type": "text",
        "default": ""
      },
      {
        "key": "completed_date",
        "type": "text",
        "default": ""
      },
      {
        "key": "location",
        "type": "text",
        "default": ""
      },
      {
        "key": "workgroup_id",
        "type": "fk_ref",
        "default": "",
        "indexed": true,
        "fk_record_type": "rt_workgroups",
        "fk_display_field": "name"
      },
      {
        "key": "city",
        "type": "fk_ref",
        "default": "",
        "fk_record_type": "rt_cities",
        "fk_display_field": "name"
      },
      {
        "key": "suburb",
        "type": "fk_ref",
        "default": "",
        "fk_record_type": "rt_suburbs",
        "fk_display_field": "name"
      }
    ]
  },
  "workflow": {
    "id": "wf_work_orders",
    "name": "Work Orders",
    "description": "Manage work order records.",
    "activities": [
      {
        "id": "act_create_work_orders",
        "name": "Create Work Order",
        "description": "Raise a new work order against a job.",
        "sort_order": 0,
        "record_map": "CREATE",
        "attributes": [
          {
            "attribute_ref": "id"
          },
          {
            "attribute_ref": "job_id"
          },
          {
            "attribute_ref": "activity_code"
          },
          {
            "attribute_ref": "problem_code"
          },
          {
            "attribute_ref": "location"
          },
          {
            "attribute_ref": "due_date"
          },
          {
            "attribute_ref": "workgroup_id"
          }
        ],
        "before_hook": null,
        "after_hook": null
      },
      {
        "id": "act_update_work_orders",
        "name": "Update Work Order",
        "description": "Update work order details.",
        "sort_order": 1,
        "record_map": "UPDATE",
        "attributes": [
          {
            "attribute_ref": "status"
          },
          {
            "attribute_ref": "start_date"
          },
          {
            "attribute_ref": "completed_date"
          },
          {
            "attribute_ref": "location"
          },
          {
            "attribute_ref": "workgroup_id"
          }
        ],
        "before_hook": null,
        "after_hook": null
      },
      {
        "id": "act_delete_work_orders",
        "name": "Delete Work Order",
        "description": "Delete this work order.",
        "sort_order": 2,
        "record_map": "DELETE",
        "attributes": [
          {
            "attribute_ref": "confirm"
          }
        ],
        "before_hook": null,
        "after_hook": null
      },
      {
        "id": "act_set_location_work_orders",
        "name": "Set Location",
        "description": "Capture the city and suburb for this work order.",
        "sort_order": 3,
        "record_map": "UPDATE",
        "attributes": [
          {
            "attribute_ref": "city",
            "required": true
          },
          {
            "attribute_ref": "suburb",
            "show_condition": "attributes.city is not null",
            "required": true
          }
        ],
        "before_hook": null,
        "after_hook": null
      }
    ]
  }
}
