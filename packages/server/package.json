{
  "name": "@fluxus/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "sideEffects": false,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "build:vercel": "esbuild src/vercel.ts --bundle --platform=node --format=esm --target=node20 --outfile=api/index.mjs --external:pg --external:@electric-sql/pglite && mkdir -p public && printf '@fluxus/server — tRPC at /trpc, health at /health\\n' > public/index.html",
    "test": "vitest run",
    "seed": "tsx scripts/seed.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.3.4",
    "@fluxus/dsl": "0.1.0",
    "@fluxus/engine": "0.1.0",
    "@hono/node-server": "^1.14.3",
    "@trpc/server": "^11.4.3",
    "drizzle-orm": "^0.44.2",
    "hono": "^4.8.3",
    "pg": "^8.16.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^24",
    "@types/pg": "^8.15.0",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.25.0",
    "tsx": "^4.20.0",
    "typescript": "^5.3.3",
    "vitest": "^3.0.0"
  }
}
